{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "commandWindows": "node.exe \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "timeout": 1
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/turn-lifecycle-hook.mjs\" UserPromptSubmit",
            "commandWindows": "node.exe \"${PLUGIN_ROOT}/scripts/turn-lifecycle-hook.mjs\" UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "commandWindows": "node.exe \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "timeout": 1
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/turn-lifecycle-hook.mjs\" Stop",
            "commandWindows": "node.exe \"${PLUGIN_ROOT}/scripts/turn-lifecycle-hook.mjs\" Stop",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "commandWindows": "node.exe \"${PLUGIN_ROOT}/scripts/lifecycle-notify.mjs\"",
            "timeout": 1
          }
        ]
      }
    ]
  }
}
